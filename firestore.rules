rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function uid() {
      return request.auth.uid;
    }

    function ownerIdFromMap(data) {
      return data.organizerId != null ? data.organizerId
           : data.createdBy != null ? data.createdBy
           : data.ownerId != null ? data.ownerId
           : data.userId;
    }

    function eventDoc(eventId) {
      return get(/databases/$(database)/documents/events/$(eventId));
    }

    function isEventOrganizer(eventId) {
      return signedIn()
        && eventDoc(eventId).exists
        && ownerIdFromMap(eventDoc(eventId).data) == uid();
    }

    // aceita participants OU members (compatibilidade com docs antigos)
    function partsFrom(data) {
      return (data.participants is list) ? data.participants
           : (data.members is list) ? data.members
           : [];
    }

    function conv(cid) {
      return get(/databases/$(database)/documents/conversations/$(cid));
    }

    function isParticipantById(cid) {
      return signedIn()
        && exists(/databases/$(database)/documents/conversations/$(cid))
        && uid() in partsFrom(conv(cid).data);
    }

    function isParticipantData(data) {
      return signedIn() && uid() in partsFrom(data);
    }

    // =========================
    // USERS
    // =========================
    match /users/{userId} {
      allow read: if signedIn();
      allow create: if signedIn() && uid() == userId;
      allow update: if signedIn() && uid() == userId;
      allow delete: if false;

      match /fcmTokens/{tokenId} {
        allow read, write: if signedIn() && uid() == userId;
      }

      match /systemInbox/{docId} {
        allow read, write: if signedIn() && uid() == userId;
      }
    }

    // =========================
    // PUBLIC PROFILES (app Remdy)
    // =========================
    match /publicUsers/{userId} {
      allow read: if signedIn();
      allow create, update: if signedIn() && uid() == userId;
      allow delete: if false;
    }

    // =========================
    // ORGANIZER PORTAL PROFILE
    // =========================
    match /organizers/{organizerId} {
      allow read: if signedIn();
      allow create, update: if signedIn() && uid() == organizerId;
      allow delete: if false;
    }

    // =========================
    // EVENTS (app + portal)
    // =========================
    match /events/{eventId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && ownerIdFromMap(request.resource.data) == uid();
      allow update: if signedIn() && isEventOrganizer(eventId);
      allow delete: if false;

      match /comments/{commentId} {
        allow read: if signedIn();
        allow create: if signedIn();
        allow update: if signedIn() && (
          isEventOrganizer(eventId)
          || resource.data.uid == uid()
          || resource.data.authorId == uid()
        );
        allow delete: if false;
      }

      match /attendees/{attendeeId} {
        allow read: if signedIn();
        allow create, update: if signedIn() && uid() == attendeeId;
        allow delete: if signedIn() && uid() == attendeeId;
      }

      match /views/{viewId} {
        allow read: if signedIn() && isEventOrganizer(eventId);
        allow create, update: if signedIn() && uid() == viewId;
        allow delete: if false;
      }
    }

    // =========================
    // CONVERSATIONS
    // =========================
    match /conversations/{cid} {
      // Usar request.auth.uid direto (funções customizadas quebram validação de query).
      allow read: if request.auth != null
        && request.auth.uid in resource.data.participants;

      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.participants
        && request.resource.data.participants is list
        && request.resource.data.participants.size() == 2;

      allow update: if request.auth != null
        && request.auth.uid in resource.data.participants;

      allow delete: if false;

      match /messages/{mid} {
        allow read: if isParticipantById(cid);

        allow create: if isParticipantById(cid)
          && request.resource.data.fromUid == uid()
          && request.resource.data.toUid in partsFrom(conv(cid).data)
          && request.resource.data.toUid != uid()
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 800;

        allow update: if false;
        allow delete: if false;
      }

      match /presence/{presenceId} {
        allow read, write: if isParticipantById(cid);
      }
    }

    // =========================
    // GROUPS
    // =========================
    match /groups/{groupId} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update: if signedIn();
      allow delete: if false;

      match /messages/{mid} {
        allow read, create: if signedIn();
        allow update, delete: if false;
      }

      match /reads/{readerId} {
        allow read: if signedIn();
        allow create, update: if signedIn() && uid() == readerId;
        allow delete: if false;
      }

      match /pendingRequests/{requestUid} {
        allow read: if signedIn();
        allow create, update: if signedIn() && uid() == requestUid;
        allow delete: if signedIn();
      }

      match /presence/{presenceId} {
        allow read, write: if signedIn();
      }
    }

    // =========================
    // POSTS / REPORTS / CONFIG
    // =========================
    match /posts/{postId} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update, delete: if signedIn()
        && resource.data.uid == uid();
    }

    match /reports/{reportId} {
      allow read: if false;
      allow create: if signedIn();
      allow update, delete: if false;
    }

    match /configCountries/{countryCode} {
      allow read: if signedIn();
      allow write: if false;
    }

    // Escritas somente via Cloud Functions (Admin SDK).
    match /boost_checkouts/{docId} {
      allow read, write: if false;
    }

    match /boost_payments/{docId} {
      allow read, write: if false;
    }

    match /portal_qr_login_sessions/{sessionId} {
      allow read, write: if false;
    }
  }
}
